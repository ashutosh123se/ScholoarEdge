<%- include('partials/head') %>
<%- include('partials/nav') %>

<section style="min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 4rem 1rem;">
  <div class="container" style="max-width: 500px;">
    <div style="font-size: 6rem; font-family: 'Playfair Display', serif; font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 1.5rem;">
      404
    </div>
    <h2 style="font-size: 1.75rem; margin-bottom: 1rem;"><%= typeof title !== 'undefined' ? title : 'Page Not Found' %></h2>
    <p style="color: var(--text-muted); margin-bottom: 2.5rem; font-size: 0.95rem;">
      <%= typeof message !== 'undefined' ? message : 'The page you are looking for does not exist, is pending publication, or has been relocated to another index.' %>
    </p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/" class="btn btn-secondary"><i class="fa-solid fa-house"></i> Return Home</a>
      <a href="/blog" class="btn btn-ghost"><i class="fa-solid fa-newspaper"></i> Read Publications</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
