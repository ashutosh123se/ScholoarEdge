<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="admin-container">
  <!-- Sidebar -->
  <%- include('../partials/admin-sidebar') %>

  <!-- Main Content -->
  <main class="admin-content">
    <div class="content-header">
      <div>
        <h1>Site Configuration Settings</h1>
        <div class="content-header-meta">Update brand titles, contact addresses, social indexes, and default editorial responses.</div>
      </div>
    </div>

    <!-- Notification Toast Alerts -->
    <%- include('../partials/flash') %>

    <% 
      // Map setting items into a config object
      const config = {};
      settingsList.forEach(row => {
        config[row.key] = row.value;
      });
    %>

    <form action="/admin/settings" method="POST" id="settings-form">
      <input type="hidden" name="csrf_token" value="<%= csrf_token %>">

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: flex-start; margin-bottom: 2.5rem;">
        
        <!-- Column 1: Site Info & Contact Details -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
          
          <!-- Site Brand Config Card -->
          <div class="dashboard-table-card">
            <h3 style="margin-bottom: 1.5rem; border-bottom: 1px solid rgba(13,27,42,0.06); padding-bottom: 0.5rem;"><i class="fa-solid fa-circle-info"></i> Brand Identity</h3>
            
            <div class="form-group">
              <label for="site_name">Brand Name</label>
              <input type="text" name="site_name" id="site_name" class="form-control" value="<%= config.site_name || 'ScholarsEdge' %>" required>
            </div>

            <div class="form-group">
              <label for="site_tagline">Tagline Slogan</label>
              <input type="text" name="site_tagline" id="site_tagline" class="form-control" value="<%= config.site_tagline || '' %>">
            </div>

            <div class="form-group">
              <label for="meta_description">SEO Meta Description</label>
              <textarea name="meta_description" id="meta_description" class="form-control" placeholder="Search engine description summary..."><%= config.meta_description || '' %></textarea>
            </div>
          </div>

          <!-- Contact Coordinates Card -->
          <div class="dashboard-table-card">
            <h3 style="margin-bottom: 1.5rem; border-bottom: 1px solid rgba(13,27,42,0.06); padding-bottom: 0.5rem;"><i class="fa-solid fa-location-arrow"></i> Communication Details</h3>
            
            <div class="form-group">
              <label for="contact_phone">Helpline Phone</label>
              <input type="tel" name="contact_phone" id="contact_phone" class="form-control" value="<%= config.contact_phone || '' %>" required>
            </div>

            <div class="form-group">
              <label for="contact_email">Support Email</label>
              <input type="email" name="contact_email" id="contact_email" class="form-control" value="<%= config.contact_email || '' %>" required>
            </div>

            <div class="form-group">
              <label for="contact_address">Office Address</label>
              <textarea name="contact_address" id="contact_address" class="form-control" required><%= config.contact_address || '' %></textarea>
            </div>
          </div>
        </div>

        <!-- Column 2: Social coordinates & Publishing presets -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
          
          <!-- Social coordinates Card -->
          <div class="dashboard-table-card">
            <h3 style="margin-bottom: 1.5rem; border-bottom: 1px solid rgba(13,27,42,0.06); padding-bottom: 0.5rem;"><i class="fa-brands fa-hashtag"></i> Social Media Links</h3>
            
            <div class="form-group">
              <label for="facebook_url">Facebook Page URL</label>
              <input type="url" name="facebook_url" id="facebook_url" class="form-control" value="<%= config.facebook_url || '' %>" placeholder="https://facebook.com/...">
            </div>

            <div class="form-group">
              <label for="twitter_url">X / Twitter Handle URL</label>
              <input type="url" name="twitter_url" id="twitter_url" class="form-control" value="<%= config.twitter_url || '' %>" placeholder="https://twitter.com/...">
            </div>

            <div class="form-group">
              <label for="linkedin_url">LinkedIn Company URL</label>
              <input type="url" name="linkedin_url" id="linkedin_url" class="form-control" value="<%= config.linkedin_url || '' %>" placeholder="https://linkedin.com/company/...">
            </div>

            <div class="form-group">
              <label for="whatsapp_number">WhatsApp Chat Number (with country code)</label>
              <input type="text" name="whatsapp_number" id="whatsapp_number" class="form-control" value="<%= config.whatsapp_number || '' %>" placeholder="e.g. +919876543210">
              <span style="font-size:0.75rem; color:var(--text-muted);">Must contain numerical characters with country prefix.</span>
            </div>
          </div>

          <!-- Editorial Presets Card -->
          <div class="dashboard-table-card">
            <h3 style="margin-bottom: 1.5rem; border-bottom: 1px solid rgba(13,27,42,0.06); padding-bottom: 0.5rem;"><i class="fa-solid fa-spell-check"></i> Editorial Desk Presets</h3>
            
            <div class="form-group" style="margin-bottom: 0;">
              <label for="default_rejection_reason">Default Rejection Explanation</label>
              <textarea name="default_rejection_reason" id="default_rejection_reason" class="form-control" style="min-height: 150px;" required><%= config.default_rejection_reason || '' %></textarea>
              <span style="font-size:0.75rem; color:var(--text-muted); margin-top: 4px; display:block;">This text auto-fills in rejection message boxes to speed up moderation cycles.</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Save triggers footer bar -->
      <div style="background-color: var(--white); padding: 1.5rem 2rem; border-radius: var(--radius-lg); box-shadow: var(--shadow); border: 1px solid rgba(13,27,42,0.03); display: flex; justify-content: flex-end;">
        <button type="submit" class="btn btn-secondary" style="padding:0.75rem 2.5rem;"><i class="fa-solid fa-save"></i> Save All Settings</button>
      </div>
    </form>
  </main>
</div>

<%- include('../partials/footer') %>
