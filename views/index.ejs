<!-- 9. CTA Section -->
<section class="cta-section">
  <div class="container">
    <h2>Ready to Elevate Your Academic Publication Index?</h2>
    <p>Schedule a confidential 1-on-1 manuscript critique call with one of our senior journal board members today.</p>
    <div class="cta-buttons">
      <a href="/contact" class="btn btn-primary"><i class="fa-solid fa-headset"></i> Book Free Consultation</a>
      <a href="https://wa.me/<%= settings.whatsapp_number ? settings.whatsapp_number.replace(/[^0-9]/g, '') : '#' %>" target="_blank" class="btn btn-ghost" style="color: var(--white); border-color: var(--white);"><i class="fa-brands fa-whatsapp"></i> Chat on WhatsApp</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
